###########################################################
#   This is a template file NOT a usable .env file        #
#   TO USE: copy to .env file (no filename) and edit      #
#   NEVER commit the actual .env file to .git repos       #
#   Keep secrets, email addresses, passwords backed up    #
###########################################################

SECRET_KEY = '<your_secret_key>'                       # e.g. 'xxxyyyzzzaaabbbcccdddeee_dont_tell!'

# Site ID configure as 1 for Aquarist Species features and 2 for Cares Species features

SITE_ID = 1
SITE_DOMAIN = '<your-domain.example.com>'              # e.g. 'aquaristspecies.net'

ALLOWED_HOST1        = 'localhost'                     # development
ALLOWED_HOST2        = '127.0.0.1'                     # development
ALLOWED_HOST3        = '*'                             # development
ALLOWED_HOST4        = ''                             # development

CSRF_TRUSTED_ORIGIN1 = 'http://localhost'              # development
CSRF_TRUSTED_ORIGIN2 = 'http://127.0.0.1'              # development 
CSRF_TRUSTED_ORIGIN3 = 'http://127.0.0.1'              # development

# ALLOWED_HOST1 = 'yourdomainname.net'                 # production
# ALLOWED_HOST2 = 'yourIPaddress'                      # production
# ALLOWED_HOST2 = 'localhost'                          # production

# CSRF_TRUSTED_ORIGIN1 = 'https://yourdomainname.net'  # production
# CSRF_TRUSTED_ORIGIN2 = 'http://yourIPaddress'        # production 

## Non-Prod Dev environment -- shared between Django and NginX-Certbot -- use 0 (False) or 1 (True)

DEBUG=1                                                # 0 for production, 1 for non-prod dev
DEBUG_TOOLBAR = 'True'                                 # Debug Toolbar requires DEBUG=1

# MariaDB Credentials

DATABASE_USER      = '<your_db_user>'                  # e.g. 'db_dude'
DATABASE_PASSWORD  = '<your_password>'                 # e.g. 'SomebodyThatIUsedToKnow12^'

## Django Super-User Credentials 

SUPER_USER_NAME = '<yourSuperuserName>'                # e.g. 'TheBigBoss'
SUPER_USER_EMAIL = '<yourEmail>'                       # e.g. 'my_real_email@example.com'
SUPER_USER_PASSWORD = '<YourSuperuserPwd>'             # e.g. 'YetAnotherSecretNotToShare12^'

## Django email 

EMAIL_HOST_USER = '<yourAppEmail>'                     #
EMAIL_HOST_PASSWORD = '<yourAppEmailPwd>'              # e.g. 'XXXX XXXXX XXXX XXXX'
DEFAULT_FROM_EMAIL = '<yourAppEmail>'                  # e.g. 'aquaristspecies@example.com'
ADMIN_EMAIL='<yourEmail>'                              # e.g. 'my_real_email@example.com'

ACCOUNT_CONFIRM_EMAIL_ON_GET = 'False'                 #set to 'True' to enable
ACCOUNT_EMAIL_VERIFICATION = 'none'                    #set to 'mandatory' to enable, 'optional' to allow verification, or 'none'

## NGINX_CBOT Certbot Notifications

CERTBOT_EMAIL = '<yourEmail>'                          # e.g. 'my_real_email@example.com'
STAGING = 1                                            # 0 for production, 1 for non-prod dev

## API Service Account (species-sync REST API, Site2 only)
## Both sites must use the same API_SERVICE_EMAIL and API_SERVICE_PASSWORD for the sync to authenticate

API_SERVICE_EMAIL    = '<api-service-email>'           # e.g. 'api_service@aquaristspecies.net'  (must be a valid email — used as HTTP Basic Auth username)
API_SERVICE_PASSWORD = '<api-service-password>'        # e.g. 'ASecureApiPassword123!'

## Target API URL for Site1 to sync CARES species from Site2
## Set on Site1 only — point to the full URL of Site2

TARGET_API_URL = '<site2-url>'                         # e.g. 'https://caresspecies.net' (local dev: 'http://localhost:8001')

