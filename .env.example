###########################################################
### This is a template file NOT a usable .env file      ###
### TO USE: copy to .env file (no filename) and edit    ###
### NEVER commit the actual .env file to .git repos     ###
### Keep secrets, email addresses, passwords backed up  ###
###########################################################

# Required Django Security Settings

SECRET_KEY='<your_secret_key>'               

###########################################################
### Project can configure 2 related sites               ###
### Site 1 is for general Aquarist 'crowd sourced' use  ###
### Site 2 is for cares registration use                ###
### SITE_ID and SITE_DOMAIN must be matched accordingly ###
###########################################################
 
SITE_ID = 1
SITE_DOMAIN = 'your_aquarist_species_domain' # e.g. aquaristspecies.net

#SITE_ID = 2
#SITE_DOMAIN = 'your_cares_species_domain'    # e.g. caresspecies.net

ALLOWED_HOST1 = 'http://localhost'           # development only - aquarist domain site 1 in production
ALLOWED_HOST2 = 'http://127.0.0.1'           # development only - server IP address in production
ALLOWED_HOST3 = 'django'                     # development and production
ALLOWED_HOST4 = '*'                          # development only - cares domain site 2 in production

# ASN_DJANGO Super User Credentials

SUPER_USER_NAME     = '<your_username>'
SUPER_USER_EMAIL    = '<your_email_address>'
SUPER_USER_PASSWORD = '<your_password>'

# DEBUG shared between Django and Nginx-Certbot set as 0 (False) or 1 (True)

DEBUG = 1                                    # development only - never use debug in production

# Debug Toolbar (requires DEBUG=1)

DEBUG_TOOLBAR = 'True'                       # development only - set to False

# NGINX_CBOT Certbot Staging Setting set as 0 (Staging=False-->Production!) or 1 (Staging=True)

STAGING = 1                                  # development only - set to 0 in production

## NGINX_CBOT Certbot Notifications - must configure HTTPS with letsencrypt in production

CERTBOT_EMAIL = '<your_letsencrypt_registered_email_address>'

# MariaDB Credentials

DATABASE_USER      = '<your_db_user>'
DATABASE_PASSWORD  = '<your_password>'

# Email 

EMAIL_USE_TLS         = 'False'                      # to enable, set to 'True'
EMAIL_HOST            = 'your_email_host>'
EMAIL_PORT            = 'your_port_number>'
EMAIL_HOST_USER       = 'your_email_host_user>'
EMAIL_HOST_PASSWORD   = '<your_email_host_password'
DEFAULT_FROM_EMAIL    = 'Notifications <your_email_address>''
ADMIN_EMAIL           = '<your_admin_email_address>'

# Google Credentials

RECAPTCHA_PUBLIC_KEY  = 'secret'
RECAPTCHA_PRIVATE_KEY = 'secret'
GOOGLE_OAUTH_LINK     = 'secret.apps.googleusercontent.com'